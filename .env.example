# Copy this file to .env and adjust if needed.
# Devnet = free test network. Keep it on devnet while learning!
RPC_URL=https://api.devnet.solana.com

# Safety interlock: scripts HARD-FAIL on any non-devnet RPC unless this is "true".
# Leave it unset. Seriously. (See docs/SECURITY-CHECKLIST.md before ever changing it.)
# I_UNDERSTAND_THIS_IS_NOT_DEVNET=true
