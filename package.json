{
  "name": "phoca",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "PHOCA ($PHOCA) — seal coin on Solana for seal lovers & seal rescue (devnet learning project)",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "wallet": "tsx scripts/01-create-wallet.ts",
    "create-token": "tsx scripts/02-create-token.ts",
    "mint-supply": "tsx scripts/03-mint-supply.ts",
    "transfer-test": "tsx scripts/04-transfer-test.ts",
    "collect-fees": "tsx scripts/05-collect-fees.ts",
    "test": "node --import=tsx --test \"tests/*.test.ts\"",
    "test:integration": "node --import=tsx --test \"tests/integration/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit --omit=dev"
  },
  "dependencies": {
    "@solana-program/system": "0.13.0",
    "@solana-program/token-2022": "0.13.0",
    "@solana/kit": "7.0.0",
    "dotenv": "16.6.1"
  },
  "devDependencies": {
    "@types/node": "24.13.2",
    "tsx": "4.23.0",
    "typescript": "5.9.3"
  }
}
